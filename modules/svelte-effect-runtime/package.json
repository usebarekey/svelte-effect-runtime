{
  "name": "svelte-effect-runtime",
  "version": "0.0.0",
  "description": "Client-side Effect runtime support for Svelte <script> blocks.",
  "license": "BSD-3-Clause",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/mod.d.ts",
      "default": "./dist/mod.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./language-server": {
      "types": "./dist/language-server.d.ts",
      "default": "./dist/language-server.js"
    },
    "./preprocess": {
      "types": "./dist/preprocess.d.ts",
      "default": "./dist/preprocess.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "default": "./dist/vite.js"
    }
  },
  "scripts": {
    "build": "deno task build",
    "build:npm": "npm run build",
    "check": "deno task check",
    "clean": "deno task clean",
    "test": "deno task test"
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "effect": "^3.0.0",
    "svelte": "^5.0.0",
    "vite": "^7.0.0 || ^8.0.0"
  },
  "dependencies": {
    "magic-string": "^0.30.21",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "jsdom": "^26.1.0",
    "rolldown": "^1.0.0-rc.13"
  }
}
