{
  "name": "svelte-effect-runtime",
  "version": "1.2.2",
  "description": "Client-side Effect runtime support for Svelte <script> blocks.",
  "license": "BSD-3-Clause",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/usebarekey/svelte-effect-runtime.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/root-node.d.ts",
      "node": "./dist/root-node.js",
      "default": "./dist/mod.js"
    },
    "./_server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./language-server": {
      "types": "./dist/language-server.d.ts",
      "default": "./dist/language-server.js"
    }
  },
  "scripts": {
    "build": "deno task build",
    "build:npm": "npm run build",
    "check": "deno task check",
    "clean": "deno task clean",
    "test": "deno task test"
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "effect": "^3.0.0",
    "svelte": "^5.0.0",
    "vite": "^7.0.0 || ^8.0.0"
  },
  "dependencies": {
    "devalue": "^5.5.0",
    "magic-string": "^0.30.21",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "jsdom": "^26.1.0",
    "rolldown": "^1.0.0-rc.13"
  }
}
