{
  "name": "@barekey/svelte-effect-runtime",
  "version": "1.3.2",
  "license": "BSD-3-Clause",
  "exports": {
    ".": "./mod.ts",
    "./v3": "./mod.ts",
    "./v4": "./v4/mod.ts",
    "./preprocess": "./preprocess.ts",
    "./v3/preprocess": "./preprocess.ts",
    "./vite": "./vite.ts",
    "./v3/vite": "./vite.ts",
    "./v4/preprocess": "./v4/preprocess.ts",
    "./v4/vite": "./v4/vite.ts",
    "./_server": "./server.ts",
    "./v3/_server": "./server.ts",
    "./v4/_server": "./v4/server.ts",
    "./language-server": "./language-server.ts"
  },
  "compilerOptions": {
    "lib": ["deno.ns", "dom", "dom.iterable", "es2022"]
  },
  "tasks": {
    "build": "deno task clean && deno run -A ../../build/runtime.ts && tsc -p tsconfig.build.json --emitDeclarationOnly && deno run -A ../../build/rewrite-runtime-dts.ts",
    "check": "deno check --node-modules-dir=auto mod.ts root-node.ts effect.ts client.ts server.ts preprocess.ts vite.ts v4/mod.ts v4/root-node.ts v4/effect.ts v4/preprocess.ts v4/server.ts v4/vite.ts tests/shared/*.ts tests/v3/*.test.ts tests/v4/*.test.ts",
    "clean": "rm -rf dist ../../dist/svelte-effect-runtime",
    "smoke:v4": "deno run -A ../../build/v4-package-smoke.ts",
    "test": "deno test --node-modules-dir=auto -A tests/v3 tests/v4",
    "coverage": "deno test --node-modules-dir=auto -A --coverage=.coverage tests/v3 tests/v4 && deno coverage .coverage",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "imports": {
    "$": "./mod.ts",
    "$/": "./",
    "$internal/": "./internal/",
    "$tests/": "./tests/",
    "@std/assert": "jsr:@std/assert@^1.0.15",
    "@std/path": "jsr:@std/path@^1.1.2",
    "svelte-effect-runtime": "./mod.ts",
    "$app/server": "./internal/app-server-shim.ts",
    "effect": "npm:effect@^3.21.0",
    "effect/": "npm:/effect@^3.21.0/",
    "@babel/parser": "npm:@babel/parser@^7.29.2",
    "devalue": "npm:devalue@^5.5.0",
    "svelte": "npm:svelte@^5.55.1",
    "svelte/": "npm:/svelte@^5.55.1/",
    "magic-string": "npm:magic-string@^0.30.21",
    "typescript": "npm:typescript@^5.9.3",
    "vite": "npm:vite@^7.3.1",
    "@sveltejs/vite-plugin-svelte": "npm:@sveltejs/vite-plugin-svelte@^6.2.4",
    "@sveltejs/kit": "npm:@sveltejs/kit@^2.56.1",
    "@sveltejs/kit/": "npm:/@sveltejs/kit@^2.56.1/",
    "@sveltejs/kit/internal/server": "npm:/@sveltejs/kit@^2.56.1/internal/server",
    "@sveltejs/adapter-static": "npm:@sveltejs/adapter-static@^3.0.10",
    "jsdom": "npm:jsdom@^26.1.0"
  },
  "publish": {
    "exclude": [
      "test/**"
    ]
  }
}
