{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "./dist",
    "declaration": true,
    "verbatimModuleSyntax": true,
    "strict": true,
    "skipLibCheck": true,
    "rewriteRelativeImportExtensions": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "types": [
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "$app/server": [
        "./internal/app-server-shim.ts"
      ],
      "@sveltejs/kit/internal/server": [
        "./internal/sveltekit-internal-server-shim.d.ts"
      ]
    }
  },
  "include": [
    "./mod.ts",
    "./root-node.ts",
    "./effect.ts",
    "./client.ts",
    "./server.ts",
    "./language-server.ts",
    "./preprocess.ts",
    "./vite.ts",
    "./internal/**/*.ts"
  ]
}
