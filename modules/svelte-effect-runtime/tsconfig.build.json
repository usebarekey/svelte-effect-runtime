{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "./dist",
    "declaration": true,
    "verbatimModuleSyntax": true,
    "strict": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "types": [
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "$": [
        "./mod.ts"
      ],
      "$/*": [
        "./*"
      ],
      "$internal/*": [
        "./internal/*"
      ],
      "$tests/*": [
        "./tests/*"
      ],
      "$app/server": [
        "./internal/app-server-shim.ts"
      ],
      "@sveltejs/kit/internal/server": [
        "./internal/sveltekit-internal-server-shim.d.ts"
      ]
    }
  },
  "include": [
    "./mod.ts",
    "./root-node.ts",
    "./v4/mod.ts",
    "./v4/root-node.ts",
    "./v4/effect.ts",
    "./v4/preprocess.ts",
    "./v4/server.ts",
    "./v4/vite.ts",
    "./effect.ts",
    "./client.ts",
    "./server.ts",
    "./language-server.ts",
    "./preprocess.ts",
    "./vite.ts",
    "./internal/**/*.ts"
  ]
}
