{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "./dist",
    "declaration": true,
    "verbatimModuleSyntax": true,
    "strict": true,
    "skipLibCheck": true,
    "rewriteRelativeImportExtensions": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  },
  "include": [
    "./mod.ts",
    "./client.ts",
    "./language-server.ts",
    "./preprocess.ts",
    "./vite.ts",
    "./internal/**/*.ts"
  ]
}
