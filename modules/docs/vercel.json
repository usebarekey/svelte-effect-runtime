{
  "outputDirectory": ".vitepress/dist",
  "functions": {
    "api/docs.js": {
      "includeFiles": "{.vitepress/dist/**/*.html,content/**/*.md,*.md}"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*\\..*)",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/docs"
    }
  ]
}
