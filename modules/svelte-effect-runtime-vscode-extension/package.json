{
  "name": "svelte-effect-runtime-vscode",
  "displayName": "Svelte Effect Runtime",
  "description": "Cursor/VS Code integration for svelte-effect-runtime grammar-aware Svelte language support.",
  "version": "1.2.3",
  "publisher": "barekey",
  "license": "BSD-3-Clause",
  "type": "module",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:svelte-effect-runtime.enableLanguageServer",
    "onCommand:svelte-effect-runtime.disableLanguageServer"
  ],
  "extensionDependencies": [
    "svelte.svelte-vscode"
  ],
  "files": [
    "dist",
    "node_modules",
    "README.md"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "svelte-effect-runtime.enableLanguageServer",
        "title": "Svelte Effect Runtime: Enable Language Server"
      },
      {
        "command": "svelte-effect-runtime.disableLanguageServer",
        "title": "Svelte Effect Runtime: Disable Language Server"
      }
    ],
    "configuration": {
      "title": "Svelte Effect Runtime",
      "properties": {
        "svelte-effect-runtime.languageServer.autoConfigure": {
          "type": "boolean",
          "default": true,
          "description": "Automatically point the Svelte extension at the bundled svelte-effect-runtime language server when the current path is unset or already managed by this extension."
        }
      }
    }
  },
  "dependencies": {
    "@jridgewell/trace-mapping": "^0.3.31",
    "magic-string": "^0.30.21",
    "svelte": "^5.55.1",
    "svelte-language-server": "^0.17.30",
    "typescript": "^5.9.2"
  }
}
